# huggingface_write_safety.rules
# Technology: huggingface | Capability: write

rule huggingface-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_huggingface_PATTERN"
  MESSAGE "Blocked an unsafe pattern in huggingface. Use the recommended best practices for 2025/2026."
}

rule huggingface-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_huggingface_API"
  MESSAGE "You are using an outdated API for huggingface. Please upgrade to the newer API."
}
